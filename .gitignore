/prototypes/

# Arquivos temporários
*.tmp
*.swp

# Coverage de testes
/coverage/

# ==========================================
# Preservar arquitetura de pastas (novo projeto)
# Ignora todos os arquivos dentro das pastas,
# mantendo apenas os .gitkeep para o commit inicial
# ==========================================
src/**
!src/**/
!src/**/.gitkeep

documentacao/**
!documentacao/**/
!documentacao/**/.gitkeep

uploads/**
!uploads/**/
!uploads/**/.gitkeep
